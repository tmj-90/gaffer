# Gaffer factory — example environment / wiring reference.
#
# Every runtime knob lives in `runner/factory.config.sh` (sourced by every runner
# script) with a `:=` default; a real env var ALWAYS wins over the file default.
# This file documents the knobs worth setting explicitly. Copy what you need into
# your shell/profile or a `.env` you source — do NOT commit secrets.
#
# IMPORTANT: always launch the dashboard via `gaffer dashboard` (it wires every
# action command below into the API's env). An ad-hoc `node packages/dispatch/dist/
# api/bin.js` launch leaves these UNSET, so the dashboard's buttons silently no-op.
# The API logs a "dispatch-api action commands — wired: …; missing: …" line at
# startup so a mis-launched dashboard is obvious.

# ── Action commands (the dashboard buttons spawn these, detached) ─────────────
# Each is a plain command STRING (whitespace-split) or a JSON argv array. Absolute
# paths so the detached child resolves them. `gaffer dashboard` sets all of these.
# $RUNNER_DIR is <repo>/runner.

# "Suggest work" — runs the product-owner skill headlessly, files DRAFT tickets.
DISPATCH_PRODUCT_OWNER_CMD="node /abs/path/to/repo/runner/bin/product-owner-run.mjs"
# The repo NAME the product-owner run suggests work for (resolved to a path via the
# dispatch DB). Usually injected per-run by the dashboard; set for a manual run.
DISPATCH_PRODUCT_OWNER_REPO=""

# "Merge" — merges an approved ticket's delivery branch.
DISPATCH_MERGE_CMD="node /abs/path/to/repo/runner/bin/merge-ticket.mjs"
# "Poll for work" — runs one factory tick (claim → deliver → review).
DISPATCH_TICK_CMD="bash /abs/path/to/repo/runner/bin/poll-once.sh"
# "Onboard a repo" — scans + registers a repo and builds its Memory digest.
DISPATCH_ONBOARD_CMD="node /abs/path/to/repo/runner/bin/onboard-run.mjs"
# Independent black-box tester runner (in_testing → pass/fail verdict).
DISPATCH_TESTER_CMD="node /abs/path/to/repo/runner/bin/tester-run.mjs"

# ── Databases + MCP wiring (the two data-plane MCP servers read these) ─────────
# Default to $GAFFER_DATA/<name>.sqlite; set explicitly to relocate factory state.
DISPATCH_DB="/abs/path/to/repo/.gaffer/dispatch.sqlite"
MEMORY_DB="/abs/path/to/repo/.gaffer/memory.sqlite"
# The built MCP server bins, substituted into .mcp.json at runtime. Default to the
# dist bins under packages/*. If unset/empty the MCP servers never start and a
# headless agent has NO create_ticket tool (it would draft into the void).
DISPATCH_MCP_BIN="/abs/path/to/repo/packages/dispatch/dist/mcp/bin.js"
MEMORY_MCP_BIN="/abs/path/to/repo/packages/memory/dist/bin/memory-mcp.js"
# The memory CLI bin (the `lg` helper / setup uses it; no --db flag, reads MEMORY_DB).
MEMORY_CLI_BIN="/abs/path/to/repo/packages/memory/dist/bin/memory.js"

# ── Headless `claude -p` bounds + routing ─────────────────────────────────────
# Wall-clock seconds before a single claude call is killed (SIGTERM).
GAFFER_TICK_TIMEOUT=1800
# Agent turn cap per claude call (passed to `claude --max-turns`). The cap is a
# checkpoint, not a wall — a hit run is preserved + parked, not discarded.
GAFFER_MAX_TURNS=200
# Total delivery attempts per tick (>=1). 1 disables the recoverable-delivery retry.
GAFFER_MAX_DELIVERY_ATTEMPTS=3
# num_turns at/above which a mid-delivery call is treated as a cap-hit (pause/park).
# Defaults to GAFFER_MAX_TURNS so a call that consumed every turn is caught.
GAFFER_CAP_DETECT_TURNS=200

# ── Budget, dashboard, security, notifications ────────────────────────────────
# Operator spend ceiling (USD) for the factory's total usage. Empty = unlimited;
# at/over it, routing stops choosing expensive models. Example: 5.00
GAFFER_BUDGET_USD=
# Dashboard URL embedded in notify events. Defaults to http://127.0.0.1:$PORT.
GAFFER_DASHBOARD_URL="http://127.0.0.1:8787"
# Local Semgrep ruleset path for the security oracle. Explicit path only — never
# the network `auto` pack. Empty disables the Semgrep oracle.
GAFFER_SEMGREP_RULESET=
# 1 = notify bodies carry only minimal fields (kind + ticket number + dashboard
# URL); redaction of richer detail is honoured at the dispatch notifier layer.
GAFFER_NOTIFY_REDACT=0
