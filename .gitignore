# Dependencies (pnpm workspace — hoisted root + per-package)
node_modules/

# Build output
dist/
build/
coverage/
*.tsbuildinfo

# Factory state + local databases (never in-tree)
.gaffer/
*.sqlite
*.sqlite-shm
*.sqlite-wal
mcp-runtime.json

# Secrets / local env
.env
.env.*
# ...but the committed wiring reference is tracked (real secrets never go in it).
!.env.example

# Local-only git hook guards (banned-name / secret check) — never committed.
.husky/*.local

# OS / editor noise
.DS_Store
*.log

# Generated per-worktree Claude config / runtime state (never committed)
.claude/
CLAUDE.factory.md
.mcp.runtime.json
mcp-runtime.json
.crew/

# runtime audit log — append-only, dirties the tree on every run (should never have been tracked)
.dispatch/audit.jsonl
