{
  "name": "memory-mcp",
  "version": "0.2.0",
  "description": "Reviewed project memory for AI coding agents. SQLite-backed MCP server + CLI: agents can suggest reusable project knowledge; humans decide what becomes trusted lore.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "memory",
    "claude",
    "claude-code",
    "cursor",
    "ai-agents",
    "coding-agents",
    "agent-memory",
    "local-memory",
    "sqlite",
    "developer-tools"
  ],
  "license": "Apache-2.0",
  "author": "tmj-90",
  "repository": {
    "type": "git",
    "url": "https://github.com/tmj-90/gaffer",
    "directory": "packages/memory"
  },
  "homepage": "https://github.com/tmj-90/gaffer/tree/main/packages/memory#readme",
  "bugs": "https://github.com/tmj-90/gaffer/issues",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "memory": "dist/bin/memory.js",
    "memory-mcp": "dist/bin/memory-mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "docs/*.md",
    "docs/adr",
    "skills"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json && chmod +x dist/bin/memory.js dist/bin/memory-mcp.js",
    "dev:cli": "tsx src/bin/memory.ts",
    "dev:mcp": "tsx src/bin/memory-mcp.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^12.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^2.1.9",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
