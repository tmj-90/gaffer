#!/usr/bin/env bash
# gaffer — friendly front door to the factory.
#
#   gaffer setup                      nothing → running: build + init + open the UI
#   gaffer onboard <path> [--standalone]   scan + register a repo (standalone scope; map to a wider scope in the Factory Map UI)
#   gaffer dashboard [--restart|--lan] start the web dashboard (--lan = token-protected, on your LAN)
#   gaffer status                     what's registered + what's running
#   gaffer demo                       run the Factory Map showcase (DRY_RUN)
#   gaffer skills [install]           list the skill library / install it into your Claude Code
#   gaffer help
#
# Everything uses the factory's own config/state under $GAFFER_DATA — no flags to remember.
set -uo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=factory.config.sh
source "$HERE/factory.config.sh"

c_grn='\033[1;32m'; c_cya='\033[1;36m'; c_yel='\033[1;33m'; c_dim='\033[2m'; c_off='\033[0m'
c_red='\033[1;31m'
say() { printf "${c_cya}gaffer${c_off} %s\n" "$*"; }
ok()  { printf "  ${c_grn}✓${c_off} %s\n" "$*"; }
warn(){ printf "  ${c_yel}!${c_off} %s\n" "$*"; }
err() { printf "  ${c_red}✗${c_off} %s\n" "$*" >&2; }

DASH_PORT="${DISPATCH_API_PORT:-8787}"
# JSON-encode one string for embedding in a JSON array literal (escape \ and ").
# Dispatch's parseCommand reads these defaults as a JSON string[] (verbatim argv),
# so a $RUNNER_DIR containing spaces stays a SINGLE argv element instead of being
# whitespace-split. No shell, no eval — pure string escaping of an operator value.
json_str() { local s="$1"; s="${s//\\/\\\\}"; s="${s//\"/\\\"}"; printf '"%s"' "$s"; }
# Build a ["bin","<runner>/bin/<script>"] JSON argv from RUNNER_DIR, space-safe.
dispatch_cmd() { printf '[%s,%s]' "$(json_str "$1")" "$(json_str "$RUNNER_DIR/bin/$2")"; }

# The dashboard's "Suggest work" button (POST /product-owner/runs) spawns this
# command, detached, with DISPATCH_PRODUCT_OWNER_REPO in its env naming the repo to
# suggest work for. It runs the product-owner skill headlessly and files draft
# tickets. JSON argv so the absolute path survives spaces in the checkout dir.
PRODUCT_OWNER_CMD="${DISPATCH_PRODUCT_OWNER_CMD:-$(dispatch_cmd node product-owner-run.mjs)}"
# Merge command the dashboard invokes when a ticket is APPROVED: attempts the
# conflict-safe merge; a conflict spawns the resolver agent + re-approval (never a
# force-merge). JSON argv so the absolute path survives spaces in the checkout dir.
MERGE_CMD="${DISPATCH_MERGE_CMD:-$(dispatch_cmd node merge-ticket.mjs)}"
# The dashboard's "Poll for work" button (POST /poll-work) spawns this: clears the
# skip files + runs a single live tick to deliver the next ready ticket on demand.
TICK_CMD="${DISPATCH_TICK_CMD:-$(dispatch_cmd bash poll-once.sh)}"
# The dashboard Memory view's "Onboard a repo" button (POST /repos/onboard) spawns
# this, detached, with DISPATCH_ONBOARD_REPO in its env naming the repo (name/id or
# path) to onboard. It runs crew's real `repo onboard` so the repo is scanned,
# registered, and its Memory digest + feature inventory land in the memory store
# the Memory views read. JSON argv so the absolute path survives spaces in the dir.
ONBOARD_CMD="${DISPATCH_ONBOARD_CMD:-$(dispatch_cmd node onboard-run.mjs)}"
# BBT-001: the independent black-box tester runner (in_testing tickets). Assembles a
# CONTRACT-ONLY context (AC + test_contract, never the diff) and records the tester's
# pass/fail verdict back through dispatch. JSON argv so the absolute path survives
# spaces in the checkout dir.
TESTER_CMD="${DISPATCH_TESTER_CMD:-$(dispatch_cmd node tester-run.mjs)}"

cmd="${1:-help}"; shift || true
case "$cmd" in

onboard)
  path="${1:-}"; [ -n "$path" ] && shift || true
  if [ -z "$path" ]; then echo "usage: gaffer onboard <path> [--standalone]   (standalone scope; map to a wider scope in the Factory Map UI)"; exit 1; fi
  abs="$(cd "$path" 2>/dev/null && pwd -P)" || { echo "  no such directory: $path"; exit 1; }
  git -C "$abs" rev-parse --git-dir >/dev/null 2>&1 || warn "not a git repo (the factory branches per ticket — you'll want one)"
  # Route through onboard-run.mjs — the SAME path the dashboard's "Onboard a repo"
  # button uses: scan + register + the claude -p analysis (real digest + features +
  # cited lore drafts) into the memory store. Standalone single-repo scope by default;
  # map it to a wider scope from the Factory Map afterwards.
  say "onboarding $abs … (scan + register + claude -p analysis → memory)"
  GAFFER_DATA="$GAFFER_DATA" DISPATCH_DB="$DISPATCH_DB" CREW_DIR="$CREW_DIR" CREW_CONFIG="$CREW_CONFIG" \
    MEMORY_DB="$MEMORY_DB" MEMORY_CLI_BIN="$MEMORY_CLI_BIN" \
    GAFFER_PLAN_MODEL="${GAFFER_PLAN_MODEL:-}" GAFFER_TICK_TIMEOUT="${GAFFER_TICK_TIMEOUT:-}" GAFFER_MAX_TURNS="${GAFFER_MAX_TURNS:-}" \
    DISPATCH_ONBOARD_REPO="$abs" node "$RUNNER_DIR/bin/onboard-run.mjs" --repo "$abs" 2>&1 \
    | grep -vE '^\{.*\}$' | sed 's/^/  /'
  # Surface a real onboard failure loudly — ${PIPESTATUS[0]} is the node exit, not sed's.
  orc=${PIPESTATUS[0]}
  if [ "$orc" -ne 0 ]; then err "onboard failed (exit $orc) — see the output above; nothing was written to memory"; exit "$orc"; fi
  gaffer_dashboard_pid >/dev/null 2>&1 && warn "dashboard is running — \`gaffer dashboard --restart\` to see the new repo"
  printf "  ${c_dim}next: map it to a scope in the Factory Map tab, or create a ticket against it.${c_off}\n"
  ;;

dashboard)
  want_lan=0; want_restart=0
  for a in "$@"; do case "$a" in --lan) want_lan=1;; --restart) want_restart=1;; esac; done
  # Precise running-detection: a recorded+validated PID (alive AND its command is
  # the dispatch api bin), not a broad `pgrep -f` that can match another checkout.
  pid="$(gaffer_dashboard_pid 2>/dev/null || true)"
  # --restart or --lan both need a fresh bind (lan changes host + auth).
  if [ -n "$pid" ] && { [ "$want_restart" = 1 ] || [ "$want_lan" = 1 ]; }; then
    kill "$pid" 2>/dev/null && say "restarting dashboard"
    rm -f "$(gaffer_dashboard_pidfile)" 2>/dev/null || true; pid=""
  fi
  if [ -n "$pid" ]; then ok "dashboard already up → http://127.0.0.1:$DASH_PORT (pid $pid)"; exit 0; fi

  if [ "$want_lan" = 1 ]; then
    # LAN bind, made safe by a bearer token (generated once, stored 0600).
    TOKFILE="$GAFFER_DATA/dashboard-token"
    [ -s "$TOKFILE" ] || { umask 077; (openssl rand -hex 16 2>/dev/null || head -c16 /dev/urandom | od -An -tx1 | tr -d ' \n') > "$TOKFILE"; }
    TOK="$(tr -d ' \n' < "$TOKFILE")"
    # LAN IP for the "open this URL" hint. macOS: ipconfig getifaddr; Linux: hostname -I
    # (first addr) or `ip route` src. Falls back to the bind address if none resolves.
    LAN="$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null \
      || { hostname -I 2>/dev/null | awk '{print $1}'; } \
      || { ip -4 route get 1 2>/dev/null | awk '{print $7; exit}'; } )"
    [ -n "$LAN" ] || LAN="0.0.0.0"
    # AFK-LOOP P1: the reachable base for push-notification deep-links (the ping
    # says "decision pending" — this is where one-tap lands the operator). Without
    # it emitDecisionGate/ticketUrl produce no link. Export so the server env picks
    # it up and persist for any child that reads it.
    export GAFFER_DASHBOARD_URL="http://$LAN:$DASH_PORT"
    # BUG #6: the factory LOOP runs as a separate process and only sees the loopback
    # default from factory.config.sh — so its loop-end AFK ping would deep-link to
    # 127.0.0.1, unreachable from a phone. Persist the reachable LAN base where the
    # loop (and status.sh) read it back, so every notify deep-links to the SAME URL
    # the dashboard serves under --lan. (factory.config.sh reads this file.)
    ( umask 077; printf '%s\n' "$GAFFER_DASHBOARD_URL" > "$GAFFER_DATA/dashboard-url" ) 2>/dev/null || true
    nohup env -u GAFFER_TICK_TIMEOUT -u GAFFER_MAX_TURNS -u GAFFER_PLAN_DEBATE -u GAFFER_PLAN_DEBATE_MODELS -u GAFFER_PLAN_DEBATE_MAX_ROUNDS -u GAFFER_PLAN_DEBATE_MIN_ESTIMATE GAFFER_DATA="$GAFFER_DATA" CREW_DIR="$CREW_DIR" CREW_CONFIG="$CREW_CONFIG" MEMORY_CLI_BIN="$MEMORY_CLI_BIN" MEMORY_DB="$MEMORY_DB" DISPATCH_DB="$DISPATCH_DB" DISPATCH_PRODUCT_OWNER_CMD="$PRODUCT_OWNER_CMD" DISPATCH_PRODUCT_OWNER_REPO="${DISPATCH_PRODUCT_OWNER_REPO:-}" DISPATCH_MERGE_CMD="$MERGE_CMD" DISPATCH_TICK_CMD="$TICK_CMD" DISPATCH_ONBOARD_CMD="$ONBOARD_CMD" DISPATCH_TESTER_CMD="$TESTER_CMD" DISPATCH_API_TOKEN="$TOK" GAFFER_DASHBOARD_URL="$GAFFER_DASHBOARD_URL" node "$DISPATCH_DIR/dist/api/bin.js" --port "$DASH_PORT" --host 0.0.0.0 >"$GAFFER_DATA/dashboard.log" 2>&1 &
    gaffer_dashboard_write_pid "$!"   # record OUR server's PID for precise restart/status
    if curl -s --retry 25 --retry-connrefused --retry-delay 1 "http://127.0.0.1:$DASH_PORT/healthz" >/dev/null 2>&1; then
      ok "dashboard up on your LAN (token-protected)"
      printf "    open:   ${c_cya}http://%s:%s${c_off}\n    token:  ${c_cya}%s${c_off}  (paste at the login prompt)\n" "$LAN" "$DASH_PORT" "$TOK"
      # AFK-LOOP P3: one-scan phone access. The QR encodes the URL WITH the token
      # (the dashboard adopts ?token=… and scrubs it from history), so scanning
      # logs you straight in — no copy-paste of the token. Optional dependency:
      # if qrencode is absent we degrade to the plain URL+token printed above.
      if command -v qrencode >/dev/null 2>&1; then
        printf "    scan to open on your phone (token embedded):\n"
        qrencode -t ANSIUTF8 "http://$LAN:$DASH_PORT/?token=$TOK" 2>/dev/null \
          || printf "    (qr render failed — use the URL + token above)\n"
      fi
    else warn "dashboard failed to start — see $GAFFER_DATA/dashboard.log"; fi
    exit 0
  fi

  # AFK-LOOP P1: local loopback base so notification deep-links resolve even for
  # the non-LAN (desktop) dashboard. --lan overrides this with the LAN address.
  export GAFFER_DASHBOARD_URL="http://127.0.0.1:$DASH_PORT"
  # BUG #6 (degrade path): a plain (non-lan) dashboard is loopback-only, so drop any
  # stale persisted LAN url — the loop then falls back to the loopback default rather
  # than deep-linking to a LAN address that is no longer being served.
  rm -f "$GAFFER_DATA/dashboard-url" 2>/dev/null || true
  nohup env -u GAFFER_TICK_TIMEOUT -u GAFFER_MAX_TURNS -u GAFFER_PLAN_DEBATE -u GAFFER_PLAN_DEBATE_MODELS -u GAFFER_PLAN_DEBATE_MAX_ROUNDS -u GAFFER_PLAN_DEBATE_MIN_ESTIMATE GAFFER_DATA="$GAFFER_DATA" CREW_DIR="$CREW_DIR" CREW_CONFIG="$CREW_CONFIG" MEMORY_CLI_BIN="$MEMORY_CLI_BIN" MEMORY_DB="$MEMORY_DB" DISPATCH_DB="$DISPATCH_DB" DISPATCH_PRODUCT_OWNER_CMD="$PRODUCT_OWNER_CMD" DISPATCH_PRODUCT_OWNER_REPO="${DISPATCH_PRODUCT_OWNER_REPO:-}" DISPATCH_MERGE_CMD="$MERGE_CMD" DISPATCH_TICK_CMD="$TICK_CMD" DISPATCH_ONBOARD_CMD="$ONBOARD_CMD" DISPATCH_TESTER_CMD="$TESTER_CMD" GAFFER_DASHBOARD_URL="$GAFFER_DASHBOARD_URL" node "$DISPATCH_DIR/dist/api/bin.js" --port "$DASH_PORT" >"$GAFFER_DATA/dashboard.log" 2>&1 &
  gaffer_dashboard_write_pid "$!"   # record OUR server's PID for precise restart/status
  if curl -s --retry 25 --retry-connrefused --retry-delay 1 "http://127.0.0.1:$DASH_PORT/api/dashboard" >/dev/null 2>&1; then
    ok "dashboard up → http://127.0.0.1:$DASH_PORT"
    # Reads work tokenless on loopback, but WRITES (onboard · plan a build · approve) need
    # the auto-provisioned token — otherwise the first write 401s with no obvious cause.
    # Hand it to the operator as a ?token= URL the SPA adopts (and scrubs from history).
    # The delivery agent never gets it: the runner scrubs DISPATCH_API_TOKEN from its env,
    # so an agent still cannot self-approve its own work over the REST API.
    # The server auto-provisions + writes the token a beat AFTER /api/dashboard first answers,
    # so poll briefly (bash-3.2-safe) for the file — otherwise on a fast machine the very first
    # `gaffer dashboard` can print the URL WITHOUT ?token=, and the first write 401s.
    _tok=""; _i=0
    while [ -z "$_tok" ] && [ "$_i" -lt 50 ]; do
      _tok="$(cat "$GAFFER_DATA/dashboard-token" 2>/dev/null)"
      [ -n "$_tok" ] && break
      sleep 0.1; _i=$((_i + 1))
    done
    if [ -n "$_tok" ]; then
      printf "    to make changes (onboard · plan · approve), open with your token:\n    ${c_cya}http://127.0.0.1:%s/?token=%s${c_off}\n" "$DASH_PORT" "$_tok"
    fi
  else warn "dashboard failed to start — see $GAFFER_DATA/dashboard.log"; fi
  ;;

status)
  # Single-pane roll-up: all three doctors + work counts + recent ticks, and a
  # notification when a human is needed. Lives in status.sh to keep it testable.
  bash "$HERE/status.sh" "$@"
  ;;

setup)
  # nothing → running: build everything, init state (with the right config), open the UI.
  bash "$HERE/setup.sh" "$@" || { echo "setup failed"; exit 1; }
  "$HERE/gaffer" dashboard
  printf "\n${c_grn}Ready.${c_off} Onboard a repo:  ${c_cya}gaffer onboard /path/to/your/repo${c_off}\n"
  ;;

demo) DRY_RUN="${DRY_RUN:-1}" bash "$HERE/demo.sh" ;;

run)
  # Live run. Without --daemon: ONE supervisor pass (drains the ready queue, honours
  # the per-day cap, then exits). With --daemon: the portable AFK loop — re-run the pass
  # every --interval seconds (default 30) until SIGINT/SIGTERM, which finish the CURRENT
  # pass then exit cleanly. This is the "walk away and it keeps working" path on Linux,
  # not just macOS. MAX_TICKS_PER_DAY still caps the day. (Read preflight.sh first.)
  _daemon=0; _interval="${GAFFER_DAEMON_INTERVAL:-30}"
  while [ $# -gt 0 ]; do
    case "$1" in
      --daemon) _daemon=1 ;;
      --interval) shift; _interval="${1:-30}" ;;
      --interval=*) _interval="${1#--interval=}" ;;
    esac
    shift || true
  done
  if [ "$_daemon" = 0 ]; then exec env DRY_RUN="${DRY_RUN:-0}" bash "$HERE/loop.sh"; fi
  say "gaffer daemon: re-running the loop every ${_interval}s — SIGINT/SIGTERM stops cleanly (finishes the current pass); MAX_TICKS_PER_DAY caps the day"
  # shellcheck source=lib/daemon.sh
  source "$HERE/lib/daemon.sh"
  GAFFER_LOOP_SH="$HERE/loop.sh" DRY_RUN="${DRY_RUN:-0}" gaffer_run_daemon "$_interval"
  ;;

skills)
  # The factory ALREADY loads every bundled skill for each ticket (tick.sh symlinks
  # $SKILLS_DIR into the agent's worktree). This command exposes the same library to
  # YOUR own Claude Code so you can use the skills interactively.
  sub="${1:-list}"; [ $# -gt 0 ] && shift || true
  case "$sub" in
    list)
      say "bundled skills ($(ls -d "$SKILLS_DIR"/*/ 2>/dev/null | wc -l | tr -d ' ')) — $SKILLS_DIR"
      for d in "$SKILLS_DIR"/*/; do [ -d "$d" ] && printf "  • %s\n" "$(basename "$d")"; done
      printf "  ${c_dim}the factory auto-loads all of these every ticket. \`gaffer skills install\` adds them to your own Claude Code.${c_off}\n"
      ;;
    install)
      scope="project"; force=0
      for a in "$@"; do case "$a" in --user) scope="user";; --project) scope="project";; --force) force=1;; esac; done
      [ "$scope" = user ] && dest="$HOME/.claude/skills" || dest="$PWD/.claude/skills"
      mkdir -p "$dest"
      n=0; skipped=0
      for d in "$SKILLS_DIR"/*/; do
        [ -d "$d" ] || continue; name="$(basename "$d")"; link="$dest/$name"
        if [ -e "$link" ] || [ -L "$link" ]; then
          if [ "$force" = 1 ]; then rm -rf "$link"; else skipped=$((skipped+1)); continue; fi
        fi
        ln -sfn "$SKILLS_DIR/$name" "$link" && n=$((n+1))
      done
      ok "installed $n skill(s) → $dest"
      [ "$skipped" -gt 0 ] && warn "$skipped already present — re-run with --force to overwrite"
      printf "  ${c_dim}symlinks track $SKILLS_DIR (repo updates flow through). Remove: rm \"$dest\"/<name>${c_off}\n"
      ;;
    *) echo "usage: gaffer skills [list | install [--user|--project] [--force]]";;
  esac
  ;;

help|*)
  sed -n '2,12p' "$HERE/gaffer" | sed 's/^# \{0,1\}//'
  ;;
esac
